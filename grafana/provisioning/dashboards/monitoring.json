    {
      "id": 2,
      "type": "timeseries",
      "title": "CPU Usage (%)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "label_replace(  label_replace(    rate(container_cpu_usage_seconds_total{image!=\"\", cpu=\"total\"}[2m]) * 100,    \"service\", \"$1\", \"image\", \".*/([^/:]+):[^:]*\"  ),  \"service\", \"$1\", \"service\", \"auth_user_service-(.*)\")",
          "legendFormat": "{{service}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true
          },
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      }
    },
