{
  "uid": "bodaboda-monitoring",
  "title": "BodaBoda — Monitoring",
  "tags": ["bodaboda", "monitoring"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "schemaVersion": 36,
  "panels": [

    { "id": 1, "type": "row", "title": "── System Health ──", "gridPos": {"h":1,"w":24,"x":0,"y":0}, "collapsed": false },

    {
      "id": 2, "type": "stat", "title": "Backend Up",
      "gridPos": {"h":3,"w":3,"x":0,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"red","value":null},{"color":"green","value":1}]}}},
      "targets": [{"datasource":"Prometheus","expr":"up{job=\"auth_service\"}","legendFormat":""}]
    },
    {
      "id": 3, "type": "stat", "title": "Active Requests",
      "gridPos": {"h":3,"w":3,"x":3,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":20}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(http_requests_inprogress{job=\"auth_service\"}) or vector(0)","legendFormat":""}]
    },
    {
      "id": 4, "type": "stat", "title": "Total Requests (30m)",
      "gridPos": {"h":3,"w":3,"x":6,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"blue","value":null}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(increase(http_request_size_bytes_count{job=\"auth_service\",handler!=\"/metrics\"}[30m]))","legendFormat":""}]
    },
    {
      "id": 5, "type": "stat", "title": "Login Success (30m)",
      "gridPos": {"h":3,"w":3,"x":9,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(increase(bodaboda_login_attempts_total{status=\"success\"}[30m])) or vector(0)","legendFormat":""}]
    },
    {
      "id": 6, "type": "stat", "title": "Login Failed (30m)",
      "gridPos": {"h":3,"w":3,"x":12,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null},{"color":"yellow","value":5},{"color":"red","value":20}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(increase(bodaboda_login_attempts_total{status=\"failed\"}[30m])) or vector(0)","legendFormat":""}]
    },
    {
      "id": 7, "type": "stat", "title": "Registrations (30m)",
      "gridPos": {"h":3,"w":3,"x":15,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(increase(bodaboda_register_attempts_total{status=\"success\"}[30m])) or vector(0)","legendFormat":""}]
    },
    {
      "id": 8, "type": "stat", "title": "DB Queries (30m)",
      "gridPos": {"h":3,"w":3,"x":18,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"blue","value":null}]}}},
      "targets": [{"datasource":"Prometheus","expr":"sum(increase(bodaboda_db_query_duration_seconds_count[30m]))","legendFormat":""}]
    },
    {
      "id": 9, "type": "stat", "title": "Active Users",
      "gridPos": {"h":3,"w":3,"x":21,"y":1},
      "options": {"reduceOptions":{"calcs":["lastNotNull"]},"colorMode":"background","graphMode":"none"},
      "fieldConfig": {"defaults":{"color":{"mode":"thresholds"},"thresholds":{"mode":"absolute","steps":[{"color":"green","value":null}]}}},
      "targets": [{"datasource":"Prometheus","expr":"bodaboda_active_users or vector(0)","legendFormat":""}]
    },

    { "id": 10, "type": "row", "title": "── API Traffic ──", "gridPos": {"h":1,"w":24,"x":0,"y":4}, "collapsed": false },

    {
      "id": 11, "type": "timeseries", "title": "Request Rate per Endpoint (req/min)",
      "gridPos": {"h":8,"w":12,"x":0,"y":5},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2},"unit":"reqps"}},
      "targets": [
        {"datasource":"Prometheus","expr":"sum by (handler) (rate(http_request_size_bytes_count{job=\"auth_service\", handler!=\"/metrics\"}[2m])) * 60","legendFormat":"{{handler}}"}
      ]
    },
    {
      "id": 12, "type": "timeseries", "title": "Login & Register Attempts (per min)",
      "gridPos": {"h":8,"w":12,"x":12,"y":5},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"sum by (status) (rate(bodaboda_login_attempts_total[2m])) * 60","legendFormat":"login {{status}}"},
        {"datasource":"Prometheus","expr":"sum by (status) (rate(bodaboda_register_attempts_total[2m])) * 60","legendFormat":"register {{status}}"}
      ]
    },
    {
      "id": 13, "type": "timeseries", "title": "Response Bytes per Endpoint (bytes/s)",
      "gridPos": {"h":8,"w":12,"x":0,"y":13},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"unit":"bytes","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"sum by (handler) (rate(http_response_size_bytes_sum{job=\"auth_service\", handler!=\"/metrics\"}[2m]))","legendFormat":"{{handler}}"}
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "Active In-Flight Requests per Endpoint",
      "gridPos": {"h":8,"w":12,"x":12,"y":13},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["lastNotNull","max"]}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"http_requests_inprogress{job=\"auth_service\"}","legendFormat":"{{handler}} [{{method}}]"}
      ]
    },

    { "id": 15, "type": "row", "title": "── Database ──", "gridPos": {"h":1,"w":24,"x":0,"y":21}, "collapsed": false },

    {
      "id": 16, "type": "timeseries", "title": "DB Query Duration p50 / p95 (ms)",
      "gridPos": {"h":8,"w":12,"x":0,"y":22},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"unit":"ms","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"histogram_quantile(0.50, sum by (le,operation) (rate(bodaboda_db_query_duration_seconds_bucket[2m]))) * 1000","legendFormat":"p50 {{operation}}"},
        {"datasource":"Prometheus","expr":"histogram_quantile(0.95, sum by (le,operation) (rate(bodaboda_db_query_duration_seconds_bucket[2m]))) * 1000","legendFormat":"p95 {{operation}}"}
      ]
    },
    {
      "id": 17, "type": "timeseries", "title": "DB Query Rate (queries/min)",
      "gridPos": {"h":8,"w":12,"x":12,"y":22},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"sum by (operation) (rate(bodaboda_db_query_duration_seconds_count[2m])) * 60","legendFormat":"{{operation}}"}
      ]
    },

    { "id": 18, "type": "row", "title": "── Container Resources ──", "gridPos": {"h":1,"w":24,"x":0,"y":30}, "collapsed": false },

    {
      "id": 19, "type": "timeseries", "title": "CPU Usage per Container (%)",
      "gridPos": {"h":8,"w":12,"x":0,"y":31},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"unit":"percent","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"label_replace(label_replace(rate(container_cpu_usage_seconds_total{image!=\"\",cpu=\"total\"}[2m])*100,\"service\",\"$1\",\"image\",\".*/([^/:]+):[^:]*\"),\"service\",\"$1\",\"service\",\"auth_user_service-(.*)\")","legendFormat":"{{service}}"}
      ]
    },
    {
      "id": 20, "type": "timeseries", "title": "Memory Usage per Container (MB)",
      "gridPos": {"h":8,"w":12,"x":12,"y":31},
      "options": {"tooltip":{"mode":"multi"},"legend":{"displayMode":"table","placement":"bottom","calcs":["mean","max"]}},
      "fieldConfig": {"defaults":{"unit":"decmbytes","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"label_replace(label_replace(container_memory_working_set_bytes{image!=\"\"},\"service\",\"$1\",\"image\",\".*/([^/:]+):[^:]*\"),\"service\",\"$1\",\"service\",\"auth_user_service-(.*)\") / 1024 / 1024","legendFormat":"{{service}}"}
      ]
    },

    { "id": 21, "type": "row", "title": "── Host Machine ──", "gridPos": {"h":1,"w":24,"x":0,"y":39}, "collapsed": false },

    {
      "id": 22, "type": "timeseries", "title": "Host CPU Usage (%)",
      "gridPos": {"h":8,"w":8,"x":0,"y":40},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"unit":"percent","max":100,"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)","legendFormat":"CPU %"}
      ]
    },
    {
      "id": 23, "type": "timeseries", "title": "Host Memory (MB)",
      "gridPos": {"h":8,"w":8,"x":8,"y":40},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"unit":"decmbytes","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / 1024 / 1024","legendFormat":"Used MB"},
        {"datasource":"Prometheus","expr":"node_memory_MemAvailable_bytes / 1024 / 1024","legendFormat":"Free MB"}
      ]
    },
    {
      "id": 24, "type": "timeseries", "title": "Network Traffic (bytes/s)",
      "gridPos": {"h":8,"w":8,"x":16,"y":40},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"unit":"bytes","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"rate(node_network_receive_bytes_total{device!=\"lo\",device!~\"veth.+|br-.+|docker.+\"}[2m])","legendFormat":"↓ {{device}}"},
        {"datasource":"Prometheus","expr":"rate(node_network_transmit_bytes_total{device!=\"lo\",device!~\"veth.+|br-.+|docker.+\"}[2m])","legendFormat":"↑ {{device}}"}
      ]
    },

    { "id": 25, "type": "row", "title": "── Backend Process ──", "gridPos": {"h":1,"w":24,"x":0,"y":48}, "collapsed": false },

    {
      "id": 26, "type": "timeseries", "title": "Backend Process CPU (s/s)",
      "gridPos": {"h":8,"w":8,"x":0,"y":49},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"rate(process_cpu_seconds_total{job=\"auth_service\"}[2m])","legendFormat":"CPU s/s"}
      ]
    },
    {
      "id": 27, "type": "timeseries", "title": "Backend Memory RSS (MB)",
      "gridPos": {"h":8,"w":8,"x":8,"y":49},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"unit":"decmbytes","custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"process_resident_memory_bytes{job=\"auth_service\"} / 1024 / 1024","legendFormat":"RSS MB"}
      ]
    },
    {
      "id": 28, "type": "timeseries", "title": "Open File Descriptors",
      "gridPos": {"h":8,"w":8,"x":16,"y":49},
      "options": {"legend":{"displayMode":"list","placement":"bottom"}},
      "fieldConfig": {"defaults":{"custom":{"lineWidth":2}}},
      "targets": [
        {"datasource":"Prometheus","expr":"process_open_fds{job=\"auth_service\"}","legendFormat":"open FDs"}
      ]
    }
  ],
  "templating": {"list": []},
  "annotations": {"list": []},
  "links": []
}
