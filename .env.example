DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/auth_db
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Example: Gmail → SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_STARTTLS=true
# Use an App Password if you have 2FA enabled on Gmail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@bodaboda.app
SMTP_STARTTLS=true

# ── SMS — Africa's Talking ────────────────────────────────────────────────────
# Sign up at https://africastalking.com — use "sandbox" username for testing.
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=BodaBoda
